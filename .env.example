# GovAssist AI — Environment Configuration
# Copy this file to backend/.env and fill in the values

# Gemini (LiteLLM)
GEMINI_API_KEY=your-gemini-key-here
PRIMARY_MODEL=gemini/gemini-1.5-flash
FALLBACK_MODEL=gemini/gemini-1.5-pro

# OpenRouter (Optional, previously used)
OPENROUTER_API_KEY=your-openrouter-key-here

# Qdrant
# Default to localhost if no production URL is given
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=gov_documents

# RAG Settings
CHUNK_SIZE=800
CHUNK_OVERLAP=100
TOP_K=5

# Session
MAX_CONTEXT_MESSAGES=10
